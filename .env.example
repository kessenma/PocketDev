DATABASE_URL=postgres://user:password@localhost:5432/pocketdev
VITE_APP_URL=http://localhost:3000
NODE_ENV=development

# Push notifications (APNs relay via Gorush)
# APNS_KEY_BASE64=<base64 of your APNs .p8 key>
# APNS_KEY_ID=<10-char key ID from Apple Developer>
# APNS_TEAM_ID=<Apple Team ID from developer.apple.com>
GORUSH_URL=http://gorush:8088

# Admin panel auth
ADMIN_PASSWORD=your-secure-password
ADMIN_EMAIL=you@example.com
