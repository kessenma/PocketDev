{
  "name": "@pocketdev/agent",
  "private": true,
  "type": "module",
  "scripts": {
    "kill": "node ../../scripts/kill-agent-port.js",
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external node-pty-prebuilt-multiarch",
    "test": "bun test",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "start": "bun run dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@pocketdev/shared": "workspace:^",
    "@simplewebauthn/server": "^13.2.2",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.28"
  },
  "optionalDependencies": {
    "node-pty-prebuilt-multiarch": "0.10.1-pre.5"
  }
}
