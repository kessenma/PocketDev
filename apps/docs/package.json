{
  "name": "@pocketdev/docs",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "kill-port": "lsof -ti:2222 | xargs kill -9 2>/dev/null || true",
    "dev": "bun run kill-port && bun --env-file=../../.env --bun vite dev --port 2222",
    "build": "bun --env-file=../../.env --bun vite build",
    "check-types": "tsc --noEmit",
    "start": "bun run kill-port && bun run server.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@pocketdev/shared": "workspace:^",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
